# Production .env template for docker-compose.prod.yml
# Copy to .env on the server and adjust before first boot.

# --- Mongo / Redis (internal docker network — leave as is) ---
MONGO_URI=mongodb://mongo:27017/?replicaSet=rs0&directConnection=true
MONGO_DB=sspl_kitchen
REDIS_URL=redis://redis:6379/0

# --- Auth ---
# REQUIRED: replace with a long random string (e.g. `openssl rand -hex 64`)
JWT_SECRET=REPLACE_ME_WITH_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# Bootstrap admin (used only when the users collection is empty).
# CHANGE THE PASSWORD BEFORE FIRST BOOT.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMeNow!

# --- CORS ---
# Production frontend lives on the same origin, so CORS is not strictly
# needed, but keep an entry for safety in case you hit /api directly.
CORS_ORIGINS=https://sunexstones.com
